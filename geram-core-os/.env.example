# ============================================================
# GERAM CORE OS — Environment Configuration
# Copy this file to `.env` and fill in your own credentials.
# This project is designed to be provider-agnostic: swap keys
# without touching any application code.
# ============================================================

# ---- Server ----
APP_ENV=development                 # development | production
APP_HOST=127.0.0.1
APP_PORT=8000
KIOSK_MODE=true                     # true if running as fullscreen kiosk HUD

# ---- Local editable workspace ----
# Empty uses the GERAM CORE OS repository root. Set a local directory to override.
GERAM_WORKSPACE_ROOT=

# ---- I.R.I.S. (light tasks / hardware control) ----
IRIS_PROVIDER=gemini
IRIS_MODEL=gemini-2.5-flash
IRIS_FALLBACK_PROVIDER=
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ---- A.R.E.S. (heavy dev tasks / code inspection) ----
ARES_PROVIDER=openai
ARES_MODEL=gpt-5.1-codex
ARES_FALLBACK_PROVIDER=
# Reasoning effort for A.R.E.S. on reasoning-capable models (o-series / gpt-5 /
# *-codex): minimal | low | medium | high. Empty disables it. Ignored by models
# that do not support reasoning.
ARES_REASONING_EFFORT=medium
OPENAI_API_KEY=your_openai_api_key_here
CODEX_MODEL=gpt-5.1-codex           # adjust to whichever Codex-capable model you use

# ---- Additional provider and provider timeouts ----
# Provider-specific timeouts are constrained to 1-300 seconds.
GROQ_API_KEY=your_groq_api_key_here
OPENAI_TIMEOUT_SECONDS=30
GEMINI_TIMEOUT_SECONDS=30
GROQ_TIMEOUT_SECONDS=30
OLLAMA_TIMEOUT_SECONDS=120          # local models may need a longer first response
# Ollama is loopback-only and needs no API key. Select it in Settings after
# installing Ollama and pulling the default model: ollama pull llama3.2:1b
CREDENTIAL_POOL_MAX_ATTEMPTS=3

# Optional absolute override outside the source tree. Empty uses OS user data.
GERAM_LOCAL_DATA_DIR=

# ---- Orchestrator ----
ORCHESTRATOR_MODE=heuristic         # heuristic | manual_override_only
DEFAULT_MODE=iris                   # fallback mode if classification is ambiguous

# ---- Agents (/agents hot-load system) ----
# The standard distribution auto-discovers the sibling ../agents directory.
# Set an absolute path only when maintaining a separate trusted agent bundle.
AGENTS_DIR=
AGENTS_AUTO_DISCOVER=true

# ---- Supabase (semantic file viewer / persistence) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_or_anon_key

# ---- Notion (semantic file viewer source) ----
NOTION_API_KEY=your_notion_integration_key
NOTION_DATABASE_ID=your_notion_database_id

# ---- Telegram (remote command channel) ----
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here
TELEGRAM_ALLOWED_CHAT_IDS=your_allowed_chat_id_here          # comma-separated whitelist, optional

# ---- Optional user integrations ----
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_ACCOUNT_EMAIL=
SPOTIFY_ACCESS_TOKEN=
OBSIDIAN_VAULT_PATH=

# ---- Tailscale (secure LAN access from second machine) ----
TAILSCALE_HOSTNAME=your-tailscale-machine-name
TRUSTED_PROXY_NETWORK=100.64.0.0/10          # Tailscale CGNAT range, adjust if needed

# ---- Logging / Telemetry ----
LOG_LEVEL=INFO
TELEMETRY_INTERVAL_SECONDS=1
CODEX_SESSION_LOG_PATH=./logs/sessions.jsonl

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
