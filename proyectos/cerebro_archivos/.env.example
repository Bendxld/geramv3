# Copia este archivo a ".env" para configurar sin tocar server.py
# Carpeta que el cerebro va a vigilar y visualizar (por defecto: todo tu home)
CEREBRO_WATCH_DIR=/home/mauri

# Host/puerto del servidor
CEREBRO_HOST=127.0.0.1
CEREBRO_PORT=8420

# Profundidad máxima de carpetas a escanear (protección ante symlinks
# en loop o árboles patológicamente profundos; tu home real rara vez
# pasa de 8-10 niveles)
CEREBRO_MAX_DEPTH=20

# Máximo de nodos hijos que se muestran por carpeta antes de agrupar
# el resto en un nodo "+N más" (se puede expandir con click)
CEREBRO_MAX_CHILDREN=150

# Máximo total de nodos en el grafo (protección de rendimiento).
# No es lo mismo que "nodos visibles": por defecto solo se renderizan
# los primeros 2 niveles, el resto queda cargado pero oculto hasta que
# hacés click para expandir una carpeta.
CEREBRO_MAX_NODES=6000
