# ============================================================
# GERAM OS v2 · PLANTILLA DE CONFIGURACIÓN
# ------------------------------------------------------------
# Copia este archivo a ".env" y pon TUS propias claves:
#     cp .env.example .env
# El .env real está en .gitignore y NUNCA se sube a GitHub.
# Ningún valor de aquí es real: son ejemplos/placeholders.
# ============================================================

# --- Instancia (IRIS = casa/sarcástica, ARES = seria/pro) ---
INSTANCE_NAME=IRIS

# --- Supabase (memoria compartida en la nube) ---
# Crea un proyecto gratis en https://supabase.com y copia la URL y la
# service key desde Project Settings > API.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_KEY=tu_supabase_service_key

# --- Gemini API Keys (cerebro principal) ---
# Sácalas gratis en https://aistudio.google.com/apikey. Puedes poner
# de 1 a 5 gratuitas (round-robin) y opcionalmente una de pago.
# Deja vacías las que no uses.
GEMINI_FREE_1=tu_gemini_key_1
GEMINI_FREE_2=
GEMINI_FREE_3=
GEMINI_FREE_4=
GEMINI_FREE_5=
GEMINI_PAY_KEY=
# Límite diario por key antes de rotar a la siguiente (opcional).
GEMINI_LIMITE_DIARIO_POR_KEY=200

# --- Seguridad / offline / sentidos ---
# Contraseña del lock, hasheada en SHA-256. Genera la tuya con:
#   python3 -c "import hashlib; print(hashlib.sha256('TU_PASS'.encode()).hexdigest())"
LOCK_PASSWORD_HASH=pon_aqui_el_hash_sha256_de_tu_password
OLLAMA_MODEL=llama3.2:1b
WHISPER_MODEL_SIZE=small
STANDBY_MINUTES=5
PIPER_VOICE_PATH=modelos/piper/es_MX-ald-medium.onnx
# Voz de edge-tts. Vacío = la elige sola según INSTANCE_NAME.
EDGE_TTS_VOICE=

# --- Groq (contenido largo / resúmenes, round-robin de 5 keys) ---
# Gratis en https://console.groq.com/keys. Pon de 1 a 5.
GROQ_FREE_1=tu_groq_key_1
GROQ_FREE_2=
GROQ_FREE_3=
GROQ_FREE_4=
GROQ_FREE_5=

# --- Notion (documentos, pendientes, finanzas, proyectos) ---
# Crea una integración en https://www.notion.so/my-integrations y
# comparte cada base de datos con ella. Los IDs salen de la URL de cada DB.
NOTION_API_KEY=tu_notion_integration_secret
NOTION_DATABASE_ID=id_de_la_db_de_documentos
NOTION_PENDIENTES_DB_ID=id_de_la_db_de_pendientes
NOTION_FINANZAS_DB_ID=id_de_la_db_de_finanzas
NOTION_PROYECTOS_DB_ID=id_de_la_db_de_proyectos

# --- Briefing diario ---
BRIEFING_HOUR=0630

# --- Google (Calendar + Gmail + Classroom), OAuth2 ---
# Descarga el credentials.json de Google Cloud Console (OAuth de escritorio)
# y ponlo en esta ruta. Ese archivo va en credenciales/ (ignorado por git).
GOOGLE_CALENDAR_CREDENTIALS_PATH=credenciales/google_credentials.json
# Cuenta escolar de Google Workspace (opcional, para Classroom).
CLASSROOM_ACCOUNT=tu.cuenta@ejemplo.edu

# --- Nexus / UANL (opcional, específico de esa universidad) ---
# Credenciales encriptadas con Fernet, nunca en texto plano.
NEXUS_ENC_PATH=credenciales/nexus.enc
NEXUS_URL=https://plataformanexus.uanl.mx/
NEXUS_TIPO_CUENTA=01

# --- Finanzas: umbral de alerta semanal de gasto ---
ALERTA_GASTO_SEMANAL=500

# --- Telegram (HUD remoto por chat) ---
# Token del bot con @BotFather. TELEGRAM_CHAT_ID es el ÚNICO chat
# autorizado (tu propio id, sácalo con @userinfobot).
TELEGRAM_BOT_TOKEN=tu_token_de_botfather
TELEGRAM_CHAT_ID=tu_chat_id

# --- Spotify (solo lectura: canción actual + historial) ---
# App gratis en https://developer.spotify.com/dashboard.
# En "Redirect URIs" agrega EXACTO el valor de SPOTIFY_REDIRECT_URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Obsidian (notas de estudio como .md en el vault) ---
OBSIDIAN_VAULT_PATH=~/Documentos/Obsidian

# --- Despliegue en la nube (opcional; déjalo en false en tu laptop) ---
# Ver config.py y cloud_bot.py. En la nube NO se cargan agentes locales
# (cámara, navegador, ejecución de código).
GERAM_MODO_NUBE=false
# PORT=8000
